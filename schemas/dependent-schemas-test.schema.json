{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "title": "DependentSchemasTest",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "use_ssl": {
      "type": "boolean"
    },
    "ssl_certificate": {
      "type": "string"
    },
    "ssl_key": {
      "type": "string"
    }
  },
  "dependentSchemas": {
    "use_ssl": {
      "properties": {
        "ssl_certificate": {
          "type": "string"
        },
        "ssl_key": {
          "type": "string"
        }
      },
      "required": ["ssl_certificate", "ssl_key"],
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
