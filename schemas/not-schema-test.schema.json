{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "value": {
      "type": "string",
      "not": {
        "$ref": "#/$defs/missing"
      }
    },
    "inline": {
      "type": "string",
      "not": {
        "pattern": "^foo$"
      }
    },
    "warning": {
      "type": "string",
      "not": {
        "deprecated": true
      }
    }
  }
}
